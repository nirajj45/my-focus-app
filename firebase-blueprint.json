{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and focus statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalTreesGrown": { "type": "integer" },
        "totalFocusTime": { "type": "integer" },
        "coins": { "type": "integer" },
        "unlockedTrees": { "type": "array", "items": { "type": "string" } },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName"]
    },
    "TreeSession": {
      "title": "Tree Session",
      "description": "A single focus session record",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "withered"] },
        "duration": { "type": "integer" },
        "species": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "status", "duration", "timestamp", "species"]
    },
    "Room": {
      "title": "Room",
      "description": "A group of friends focusing together",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdBy", "createdAt"]
    },
    "RoomMember": {
      "title": "Room Member",
      "description": "A member of a room with their current stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalTreesGrown": { "type": "integer" },
        "totalFocusTime": { "type": "integer" },
        "coins": { "type": "integer" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "joinedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles for leaderboard"
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "TreeSession",
      "description": "Individual focus sessions"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Rooms for group focus"
    },
    "/rooms/{roomId}/members/{userId}": {
      "schema": "RoomMember",
      "description": "Members of a room"
    }
  }
}
